{
  "name": "@peerigon/configs",
  "version": "0.0.0-semantically-released",
  "description": "Configs for ESLint, Oxlint, Prettier, Oxfmt, TypeScript & friends",
  "keywords": [
    "configs",
    "eslint",
    "oxfmt",
    "oxlint",
    "peerigon",
    "prettier",
    "typescript"
  ],
  "homepage": "https://github.com/peerigon/configs#readme",
  "bugs": {
    "url": "https://github.com/peerigon/configs/issues"
  },
  "license": "MIT",
  "author": "Peerigon GmbH <hello@peerigon.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peerigon/configs.git"
  },
  "bin": {
    "verify-publishable": "dist/semantic-release/verify-publishable.js"
  },
  "files": [
    "dist",
    "ai",
    "README.md"
  ],
  "type": "module",
  "exports": {
    "./eslint/presets/javascript": "./dist/eslint/presets/javascript.js",
    "./eslint/presets/javascript-browser": "./dist/eslint/presets/javascript-browser.js",
    "./eslint/presets/javascript-node": "./dist/eslint/presets/javascript-node.js",
    "./eslint/presets/typescript": "./dist/eslint/presets/typescript.js",
    "./eslint/presets/typescript-node": "./dist/eslint/presets/typescript-node.js",
    "./eslint/presets/typescript-react": "./dist/eslint/presets/typescript-react.js",
    "./eslint/rules/base": "./dist/eslint/rules/base.js",
    "./eslint/rules/browser": "./dist/eslint/rules/browser.js",
    "./eslint/rules/javascript": "./dist/eslint/rules/javascript.js",
    "./eslint/rules/node": "./dist/eslint/rules/node.js",
    "./eslint/rules/playwright": "./dist/eslint/rules/playwright.js",
    "./eslint/rules/react": "./dist/eslint/rules/react.js",
    "./eslint/rules/tanstack-query": "./dist/eslint/rules/tanstack-query.js",
    "./eslint/rules/typescript": "./dist/eslint/rules/typescript.js",
    "./eslint/rules/vitest": "./dist/eslint/rules/vitest.js",
    "./eslint/styles/jsx-no-literals": "./dist/eslint/styles/jsx-no-literals.js",
    "./eslint/styles/no-default-export": "./dist/eslint/styles/no-default-export.js",
    "./eslint/styles/no-null": "./dist/eslint/styles/no-null.js",
    "./eslint/styles/prefer-array-shorthand": "./dist/eslint/styles/prefer-array-shorthand.js",
    "./eslint/styles/prefer-interface": "./dist/eslint/styles/prefer-interface.js",
    "./oxlint/presets/javascript": "./dist/oxlint/presets/javascript.js",
    "./oxlint/presets/javascript-browser": "./dist/oxlint/presets/javascript-browser.js",
    "./oxlint/presets/javascript-node": "./dist/oxlint/presets/javascript-node.js",
    "./oxlint/presets/typescript": "./dist/oxlint/presets/typescript.js",
    "./oxlint/presets/typescript-node": "./dist/oxlint/presets/typescript-node.js",
    "./oxlint/presets/typescript-react": "./dist/oxlint/presets/typescript-react.js",
    "./oxlint/rules/base": "./dist/oxlint/rules/base.js",
    "./oxlint/rules/browser": "./dist/oxlint/rules/browser.js",
    "./oxlint/rules/javascript": "./dist/oxlint/rules/javascript.js",
    "./oxlint/rules/node": "./dist/oxlint/rules/node.js",
    "./oxlint/rules/playwright": "./dist/oxlint/rules/playwright.js",
    "./oxlint/rules/react": "./dist/oxlint/rules/react.js",
    "./oxlint/rules/tanstack-query": "./dist/oxlint/rules/tanstack-query.js",
    "./oxlint/rules/typescript": "./dist/oxlint/rules/typescript.js",
    "./oxlint/rules/vitest": "./dist/oxlint/rules/vitest.js",
    "./oxlint/styles/jsx-no-literals": "./dist/oxlint/styles/jsx-no-literals.js",
    "./oxlint/styles/no-default-export": "./dist/oxlint/styles/no-default-export.js",
    "./oxlint/styles/no-null": "./dist/oxlint/styles/no-null.js",
    "./oxlint/styles/prefer-array-shorthand": "./dist/oxlint/styles/prefer-array-shorthand.js",
    "./oxlint/styles/prefer-interface": "./dist/oxlint/styles/prefer-interface.js",
    "./oxfmt": "./dist/oxfmt/base.js",
    "./prettier": "./dist/prettier/base.js",
    "./semantic-release": "./dist/semantic-release/base.js",
    "./semantic-release/cross-publish": "./dist/semantic-release/cross-publish.js",
    "./typescript": "./dist/typescript/base.json",
    "./typescript/lib": "./dist/typescript/lib.json",
    "./typescript/js-lib": "./dist/typescript/js-lib.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "run-s build:*",
    "build:clear": "rimraf dist",
    "build:tsc": "tsc",
    "build:jsr-typescript-configs": "node tools/prepare-jsr-publish-assets.js",
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "release": "semantic-release",
    "test": "run-p test:* test:presets:* test:rules:* test:styles:* test:oxlint:*",
    "test:format": "oxfmt --check .",
    "test:lint": "eslint --cache --max-warnings 0 .",
    "test:publishable": "node ./semantic-release/verify-publishable.js",
    "test:snapshot": "node eslint/config-snapshot.test.js",
    "test:snapshot:update": "node eslint/config-snapshot.test.js --update",
    "test:presets:javascript": "cd eslint/presets/javascript.test; eslint --cache --max-warnings 0 .",
    "test:presets:typescript": "cd eslint/presets/typescript.test; eslint --cache --max-warnings 0 .",
    "test:presets:typescript-react": "cd eslint/presets/typescript-react.test; eslint --cache --max-warnings 0 .",
    "test:rules:vitest": "cd eslint/rules/vitest.test; eslint --cache --max-warnings 0 .",
    "test:styles:jsx-no-literals": "cd eslint/styles/jsx-no-literals.test; eslint --cache --max-warnings 0 .",
    "test:styles:no-default-export": "cd eslint/styles/no-default-export.test; eslint --cache --max-warnings 0 .",
    "test:styles:no-null": "cd eslint/styles/no-null.test; eslint --cache --max-warnings 0 .",
    "test:styles:prefer-array-shorthand": "cd eslint/styles/prefer-array-shorthand.test; eslint --cache --max-warnings 0 .",
    "test:styles:prefer-interface": "cd eslint/styles/prefer-interface.test; eslint --cache --max-warnings 0 .",
    "test:oxlint:typescript": "cd oxlint/presets/typescript.test; oxlint -c oxlint.config.js --deny-warnings .",
    "test:oxlint:typescript-react": "cd oxlint/presets/typescript-react.test; oxlint -c oxlint.config.js --deny-warnings .",
    "test:oxlint:no-default-export": "cd oxlint/styles/no-default-export.test; oxlint -c oxlint.config.js --deny-warnings .",
    "test:oxlint:snapshot": "node oxlint/config-snapshot.test.js",
    "test:oxlint:snapshot:update": "node oxlint/config-snapshot.test.js --update",
    "test:oxfmt": "cd oxfmt/base.test; oxfmt --check .",
    "test:types": "tsc --noEmit"
  },
  "dependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@eslint-react/eslint-plugin": "^5.9.5",
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^9.39.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@prettier/plugin-oxc": "^0.1.3",
    "@sebbo2002/semantic-release-jsr": "^4.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@tanstack/eslint-plugin-query": "^5.101.0",
    "@types/eslint-config-prettier": "^6.11.3",
    "@vitest/eslint-plugin": "^1.6.14",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y-x": "^0.2.0",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-react-you-might-not-need-an-effect": "^1.0.1",
    "eslint-plugin-unicorn": "^65.0.1",
    "globals": "^17.4.0",
    "oxlint-plugin-eslint": "^1.73.0",
    "prettier-plugin-css-order": "^2.2.0",
    "prettier-plugin-jsdoc": "^1.8.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "publint": "^0.3.21",
    "typescript-eslint": "^8.61.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.14",
    "@types/signale": "^1.4.7",
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "pin-github-action": "^3.4.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "eslint": "^9.38.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "prettier": "^3.6.2",
    "semantic-release": "^25.0.1",
    "typescript": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    },
    "oxfmt": {
      "optional": true
    },
    "oxlint": {
      "optional": true
    },
    "oxlint-tsgolint": {
      "optional": true
    },
    "prettier": {
      "optional": true
    },
    "semantic-release": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "error"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
